<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.MainPage"
             Title="Perfil del Alumno">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15" MaximumWidthRequest="500" HorizontalOptions="Center">

            <Frame CornerRadius="75" HeightRequest="150" WidthRequest="150" HorizontalOptions="Center" IsClippedToBounds="True" Padding="0">
                <Image Source="{Binding ProfileImageUrl}" Aspect="AspectFill" />
            </Frame>

            <Label Text="{Binding Name, StringFormat='Perfil de: {0}'}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />

            <Label Text="Nombre:" FontAttributes="Bold" />
            <Entry Text="{Binding Name, Mode=TwoWay}" Placeholder="Ingresa tu nombre" />

            <Label Text="Edad:" FontAttributes="Bold" />
            <Entry Text="{Binding Age, Mode=TwoWay}" Keyboard="Numeric" Placeholder="Ingresa tu edad" />

            <Label Text="Descripción:" FontAttributes="Bold" />
            <Editor Text="{Binding Description, Mode=TwoWay}" HeightRequest="100" Placeholder="Escribe una breve descripción" />

            <Label Text="{Binding StatusMessage}" TextColor="Red" FontAttributes="Bold" HorizontalOptions="Center" />

            <Button Text="Guardar Cambios" Command="{Binding SaveCommand}" Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>