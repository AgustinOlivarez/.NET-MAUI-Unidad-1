<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiApp1.ViewModels"
             x:Class="MauiApp1.Views.PlayerDetailPage"
             Title="Detalle del Jugador">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Nombre Completo:" FontSize="16" TextColor="Gray" />
        <Label Text="{Binding Player.Nombre}" FontSize="24" FontAttributes="Bold" />

        <Label Text="Posición:" FontSize="16" TextColor="Gray" Margin="0,15,0,0" />
        <Label Text="{Binding Player.Posicion}" FontSize="20" />

        <Label Text="Equipo:" FontSize="16" TextColor="Gray" Margin="0,15,0,0" />
        <Label Text="{Binding Player.Equipo}" FontSize="20" />
    </VerticalStackLayout>
</ContentPage>
